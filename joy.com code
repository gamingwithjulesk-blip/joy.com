// ─── Palette ───────────────────────────────────────────────────────────────────

interface PaletteColor { hex: string; name: string; role: string; }
interface GeneratedPalette { name: string; colors: PaletteColor[]; }

const PALETTE_NAMES = [
  "Nocturne Wings", "Luna Dust", "Forest Phantom", "Silk Moth", "Night Bloomer",
  "Dusk Emergence", "Velvet Antennae", "Ancient Scales", "Moonpowder", "Shadow Garden",
  "Dappled Wing", "Twilight Chrysalis", "Amber Fade", "Still Water", "Ember Ash",
  "Pale Emergence", "Ink & Petal", "Fog & Rust",
];

function hslToHex(h: number, s: number, l: number): string {
  s /= 100; l /= 100;
  const a = s * Math.min(l, 1 - l);
  const f = (n: number) => {
    const k = (n + h / 30) % 12;
    const c = l - a * Math.max(Math.min(k - 3, 9 - k, 1), -1);
    return Math.round(255 * c).toString(16).padStart(2, "0");
  };
  return `#${f(0)}${f(8)}${f(4)}`;
}

function buildPalette(): GeneratedPalette {
  const h = Math.floor(Math.random() * 360);
  const s = 12 + Math.floor(Math.random() * 28);
  const colors: PaletteColor[] = [
    { hex: hslToHex(h, s * 0.5, 12),           name: "Depth",  role: "base / bottoms" },
    { hex: hslToHex((h + 20) % 360, s * 0.8, 30), name: "Anchor", role: "jacket / bag" },
    { hex: hslToHex((h + 40) % 360, s, 52),    name: "Body",   role: "main garment" },
    { hex: hslToHex((h + 180) % 360, s * 0.6, 72), name: "Lift",   role: "accent / scarf" },
    { hex: hslToHex((h + 200) % 360, s * 0.3, 88), name: "Breath", role: "jewelry / details" },
  ];
  return { name: PALETTE_NAMES[Math.floor(Math.random() * PALETTE_NAMES.length)], colors };
}

