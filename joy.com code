                    className={`flex items-center gap-1.5 text-xs tracking-[0.18em] uppercase px-3.5 py-2 border transition-all ${
                      galleryFilter === f
                        ? "border-primary text-foreground bg-primary/10"
                        : "border-border text-muted-foreground hover:text-foreground hover:border-muted-foreground"
                    }`}
                  >
                    {f === "liked"      && <Heart className="w-3 h-3" />}
                    {f === "bookmarked" && <Bookmark className="w-3 h-3" />}
                    {f}
                  </button>
                ))}
              </div>
              <span className="text-xs text-muted-foreground/50">
                {images.filter(i =>
                  galleryFilter === "all" ? true :
                  galleryFilter === "liked" ? i.liked : i.bookmarked
                ).length} photo{images.length !== 1 ? "s" : ""}
              </span>
            </div>
          )}

          {images.length > 0 ? (() => {
            const visible = images.filter(i =>
              galleryFilter === "all" ? true :
              galleryFilter === "liked" ? i.liked : i.bookmarked
            );
            return visible.length > 0 ? (
              <div className="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-2.5">
                {visible.map(img => (
                  <div key={img.id} className="group relative aspect-square overflow-hidden bg-muted">
                    <img
                      src={img.url}
                      alt={img.name}
                      className="w-full h-full object-cover transition-transform duration-500 group-hover:scale-[1.04]"
                    />

                    {/* persistent indicators when active */}
                    {(img.liked || img.bookmarked) && (
                      <div className="absolute top-2 left-2 flex gap-1.5 pointer-events-none">
                        {img.liked && (
                          <span className="w-5 h-5 flex items-center justify-center bg-black/50">
                            <Heart className="w-2.5 h-2.5 fill-current text-rose-400" />
                          </span>
                        )}
                        {img.bookmarked && (
                          <span className="w-5 h-5 flex items-center justify-center bg-black/50">
                            <Bookmark className="w-2.5 h-2.5 fill-current text-accent" />
                          </span>
                        )}
                      </div>
                    )}

                    {/* hover overlay */}
                    <div className="absolute inset-0 bg-black/55 opacity-0 group-hover:opacity-100 transition-opacity flex flex-col justify-between p-2">
                      {/* top row: remove */}
                      <div className="flex justify-end">
                        <button
                          onClick={() => removeImage(img.id)}
                          aria-label="Remove image"
                          className="w-6 h-6 bg-background/80 flex items-center justify-center hover:bg-destructive hover:text-destructive-foreground transition-colors text-foreground"
                        >
                          <X className="w-3 h-3" />
                        </button>
                      </div>
                      {/* bottom row: like + bookmark */}
                      <div className="flex gap-1.5">
                        <button
                          onClick={() => toggleLike(img.id)}
                          aria-label={img.liked ? "Unlike" : "Like"}
                          className={`flex items-center gap-1 px-2 py-1 text-xs border transition-all ${
                            img.liked
                              ? "border-rose-400/80 text-rose-400 bg-rose-400/15"
                              : "border-white/30 text-white/80 hover:border-rose-400/60 hover:text-rose-400"
                          }`}
                        >
                          <Heart className={`w-3 h-3 ${img.liked ? "fill-current" : ""}`} />
                          {img.liked ? "Liked" : "Like"}
                        </button>
                        <button
                          onClick={() => toggleBookmark(img.id)}
                          aria-label={img.bookmarked ? "Remove bookmark" : "Bookmark"}
                          className={`flex items-center gap-1 px-2 py-1 text-xs border transition-all ${
                            img.bookmarked
                              ? "border-accent/80 text-accent bg-accent/15"
                              : "border-white/30 text-white/80 hover:border-accent/60 hover:text-accent"
                          }`}
                        >
                          <Bookmark className={`w-3 h-3 ${img.bookmarked ? "fill-current" : ""}`} />
                          {img.bookmarked ? "Saved" : "Save"}
                        </button>
                      </div>
                    </div>
                  </div>
                ))}
              </div>
            ) : (
              <div className="text-center py-14 text-muted-foreground/30">
                <p className="text-sm" style={{ fontFamily: "var(--font-serif)", fontStyle: "italic" }}>
                  No {galleryFilter} photos yet.
                </p>
              </div>
            );
          })() : (
            <div className="text-center py-14 text-muted-foreground/30">
              <ImageIcon className="w-12 h-12 mx-auto mb-3 opacity-25" />
              <p className="text-sm" style={{ fontFamily: "var(--font-serif)", fontStyle: "italic" }}>
                Nothing here yet — upload something.
              </p>
            </div>
          )}
        </div>
      </section>

      {/* ── Footer ── */}
      <footer className="py-14 border-t border-border text-center">
        <MothSVG className="w-8 h-8 text-primary/30 mx-auto mb-4" />
        <p className="text-xs tracking-[0.35em] text-rainbow uppercase font-display opacity-60">
          joy.com &mdash; for night creatures
        </p>
      </footer>
    </div>
  );
}





