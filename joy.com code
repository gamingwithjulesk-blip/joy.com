  const [paletteVis, setPaletteVis]   = useState(true);

  // breathwork & grounding
  const [calmTechnique, setCalmTechnique]   = useState<"breathing" | "grounding">("breathing");
  const [breathActive, setBreathActive]     = useState(false);
  const [breathPhase, setBreathPhase]       = useState(0);
  const [breathCount, setBreathCount]       = useState(BOX_PHASES[0].duration);
  const [groundStep, setGroundStep]         = useState(0);
  const [groundDone, setGroundDone]         = useState(false);
  const breathRef                           = useRef<ReturnType<typeof setInterval> | null>(null);

  // activities
  const [activityFilter, setActivityFilter] = useState<ActivityFilter>("all");
  const [activity, setActivity]             = useState<Activity | null>(null);
  const [activityVis, setActivityVis]       = useState(true);
  const [activityHistory, setActivityHistory] = useState<Activity[]>([]);

  // gallery
  const [images, setImages]           = useState<GalleryImage[]>([]);
  const [dragOver, setDragOver]       = useState(false);
  const [galleryFilter, setGalleryFilter] = useState<"all" | "liked" | "bookmarked">("all");
  const fileRef                       = useRef<HTMLInputElement>(null);

  // scroll spy
  useEffect(() => {
    const ids = ["hero", "affirmations", "songs", "palette", "activities", "calm", "gallery"];
    const obs = new IntersectionObserver(
      (entries) => entries.forEach(e => { if (e.isIntersecting) setActiveSection(e.target.id); }),
      { threshold: 0.35 }
    );
    ids.forEach(id => { const el = document.getElementById(id); if (el) obs.observe(el); });
    return () => obs.disconnect();
  }, []);

  const scrollTo = (id: string) => document.getElementById(id)?.scrollIntoView({ behavior: "smooth" });

  // ── Affirmation ──
  const nextAffirmation = () => {
    setAffirmVis(false);
    setTimeout(() => {
      setAffirmIdx(prev => {
        let n: number;
        do { n = Math.floor(Math.random() * AFFIRMATIONS.length); } while (n === prev);
        return n;
      });
      setAffirmVis(true);
    }, 280);
  };

  // ── Song ──
  const pickSong = () => {
    if (!mood) return;
    setSongVis(false);
    setTimeout(() => { setSong(SONGS[mood][Math.floor(Math.random() * SONGS[mood].length)]); setSongVis(true); }, 280);
  };

  // ── Breathing ──
  useEffect(() => {
    if (!breathActive) { if (breathRef.current) clearInterval(breathRef.current); return; }
    breathRef.current = setInterval(() => {
      setBreathCount(prev => {
        if (prev > 1) return prev - 1;
        setBreathPhase(p => {
          const next = (p + 1) % BOX_PHASES.length;
          setBreathCount(BOX_PHASES[next].duration);
          return next;
        });
        return BOX_PHASES[0].duration;
      });
    }, 1000);
    return () => { if (breathRef.current) clearInterval(breathRef.current); };
  }, [breathActive]);

  const startBreathing = () => { setBreathPhase(0); setBreathCount(BOX_PHASES[0].duration); setBreathActive(true); };
  const stopBreathing  = () => { setBreathActive(false); setBreathPhase(0); setBreathCount(BOX_PHASES[0].duration); };

  const resetGrounding = () => { setGroundStep(0); setGroundDone(false); };

  // ── Activities ──
  const pickActivity = () => {
    const pool = activityFilter === "all"
      ? ACTIVITIES
      : ACTIVITIES.filter(a => a.category === activityFilter);
    setActivityVis(false);
    setTimeout(() => {
      const next = pool[Math.floor(Math.random() * pool.length)];
      setActivity(next);
