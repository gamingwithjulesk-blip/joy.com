const LIKES_KEY = 'artGallery.likes.v1';
let likedImages = new Set();
const viewerLikeBtn = document.getElementById('viewerLikeBtn');

function saveLikes() {
  try {
    localStorage.setItem(LIKES_KEY, JSON.stringify(Array.from(likedImages)));
      } catch (e) {
    console.warn('Could not save liked image IDs', e);
  }
}

function loadLikes() {
  const raw = localStorage.getItem(LIKES_KEY);
  if (!raw) return;
  try {
      likedImages = new Set(JSON.parse(raw));
  } catch (e) {
    likedImages = new Set();
  }
}

